{
  "name": "cv-raul-alvarez",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsx --tsconfig tsconfig.app.json scripts/generate-sitemap.ts && tsx --tsconfig tsconfig.app.json scripts/prerender.tsx && tsx --tsconfig tsconfig.app.json scripts/validate-prerender.ts",
    "validate-llms-txt": "tsx --tsconfig tsconfig.app.json scripts/validate-llms-txt.ts",
    "validate-articles": "tsx --tsconfig tsconfig.app.json scripts/validate-articles.ts",
    "validate-articles:fix": "tsx --tsconfig tsconfig.app.json scripts/validate-articles.ts --fix",
    "fetch-project-logos": "tsx --tsconfig tsconfig.app.json scripts/fetch-project-logos.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "lucide-react": "^0.563.0",
    "motion": "^12.29.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "critters": "^0.0.23",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "simple-icons": "^16.11.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
