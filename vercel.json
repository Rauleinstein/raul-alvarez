{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; media-src 'self' data:; script-src 'self' 'unsafe-inline' https://vercel.live; style-src 'self' 'unsafe-inline' https://vercel.live; font-src 'self' https://vercel.live; img-src 'self' data: https:; connect-src 'self' https://vercel.live https://*.pusher.com wss://*.pusher.com https://va.vercel-scripts.com https://vitals.vercel-insights.com wss://api.openai.com https://api.openai.com; frame-src 'self' https://vercel.live https://player.mux.com https://www.youtube.com; frame-ancestors 'self'; form-action 'self'; base-uri 'self'; object-src 'none'"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self), geolocation=()"
        },
        {
          "key": "X-Open-To",
          "value": "interesting-problems"
        },
        {
          "key": "X-Resume",
          "value": "/llms.txt"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/en/", "destination": "/en", "permanent": true },
    { "source": "/:path+/", "destination": "/:path+", "permanent": true }
  ],
  "rewrites": [
    { "source": "/en", "destination": "/en/index.html" },
    { "source": "/sobre-mi", "destination": "/sobre-mi/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/privacidad", "destination": "/privacidad/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/custodio-digital", "destination": "/custodio-digital/index.html" },
    { "source": "/custodio-digital-en", "destination": "/custodio-digital-en/index.html" },
    { "source": "/powermark", "destination": "/powermark/index.html" },
    { "source": "/powermark-en", "destination": "/powermark-en/index.html" },
    { "source": "/cityhunts", "destination": "/cityhunts/index.html" },
    { "source": "/cityhunts-en", "destination": "/cityhunts-en/index.html" },
    { "source": "/el-caso-munford", "destination": "/el-caso-munford/index.html" },
    { "source": "/el-caso-munford-en", "destination": "/el-caso-munford-en/index.html" },
    { "source": "/feria-libro-granada", "destination": "/feria-libro-granada/index.html" },
    { "source": "/feria-libro-granada-en", "destination": "/feria-libro-granada-en/index.html" },
    { "source": "/cgv-seguros", "destination": "/cgv-seguros/index.html" },
    { "source": "/cgv-seguros-en", "destination": "/cgv-seguros-en/index.html" },
    { "source": "/esdrujula-ediciones", "destination": "/esdrujula-ediciones/index.html" },
    { "source": "/esdrujula-ediciones-en", "destination": "/esdrujula-ediciones-en/index.html" },
    { "source": "/entradasytickets", "destination": "/entradasytickets/index.html" },
    { "source": "/entradasytickets-en", "destination": "/entradasytickets-en/index.html" },
    { "source": "/atlantis", "destination": "/atlantis/index.html" },
    { "source": "/atlantis-en", "destination": "/atlantis-en/index.html" },
    { "source": "/omega-protocol", "destination": "/omega-protocol/index.html" },
    { "source": "/omega-protocol-en", "destination": "/omega-protocol-en/index.html" },
    { "source": "/dungeonkeeper", "destination": "/dungeonkeeper/index.html" },
    { "source": "/dungeonkeeper-en", "destination": "/dungeonkeeper-en/index.html" }
  ]
}
